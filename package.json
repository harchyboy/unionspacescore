{
  "name": "union-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:open": "vite --open",
    "dev:local": "cross-env VITE_ENV=local vite",
    "dev:local:open": "cross-env VITE_ENV=local vite --open",
    "build": "node build-static.js",
    "build:vercel": "vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "open": "start http://localhost:5173/properties",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('husky', {stdio: 'inherit'})\"",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./auto-deploy.ps1",
    "deploy:msg": "powershell -ExecutionPolicy Bypass -File ./auto-deploy.ps1 -CommitMessage"
  },
  "dependencies": {
    "msw": "^2.12.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@esbuild/win32-arm64": "0.25.12",
    "@eslint/js": "^9.39.1",
    "@rollup/rollup-win32-arm64-msvc": "^4.53.2",
    "@vercel/node": "^5.5.5",
    "@types/node": "^24.10.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
